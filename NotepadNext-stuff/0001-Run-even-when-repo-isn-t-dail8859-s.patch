From 38482d00cdcbd2cff555b8052204720b0897c2c8 Mon Sep 17 00:00:00 2001
From: Matthew Yang <matthew.yang204@gmail.com>
Date: Wed, 4 Feb 2026 06:55:56 -0800
Subject: [PATCH] Run even when repo isn't dail8859's

---
 .github/workflows/build.yml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.github/workflows/build.yml b/.github/workflows/build.yml
index 1c39390..274d14e 100644
--- a/.github/workflows/build.yml
+++ b/.github/workflows/build.yml
@@ -136,7 +136,7 @@ jobs:
     runs-on: ubuntu-latest
     needs: [build]
 
-    if: github.repository == 'dail8859/NotepadNext' && github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')
+    if: github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')
     
     env:
       GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
-- 
2.52.0

